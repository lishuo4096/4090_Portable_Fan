  68          void UART1_Init(void){//115200bps@24.000MHz
  69   1          SCON = 0x50;        //8位数据,可变波特率，允许接受
  70   1          AUXR |= 0x01;//串口1选择定时器2为波特率发生器
  71   1          AUXR |= 0x04;//定时器时钟1T模式
  72   1          T2H = ((UART_Timer_Reload_Value >> 8) & 0xff);//设置定时初始值
  73   1          T2L = (UART_Timer_Reload_Value & 0xff);//设置定时初始值
  74   1          AUXR &= ~0X10;//定时器2初始化后停止计时，开机后才继续计时
  75   1      }
  76          void TouchKey_Init(){
  77   1          P_SW2 |= 0X80;//允许访问扩展寄存器
  78   1          TSCHEN1 = 0X02;//TK1，P11通道使能//如果有多个按键的话，最好在休眠后关闭除了开关机键以外的按键使能
  79   1          TSCFG1 = 0x26;//实测22nf下5000时钟放电已足够//测试发现4MHZ下工作的更好，返回值正常，推测可能是3MHZ下和
             -触摸天线谐振了
  80   1          TSCFG2 = 0x03;//触摸按键控制器参考电压3/4 VCC
  81   1          TSSTA2 = 0XC0;//清零触摸按键状态寄存器(包括完成标志，溢出标志，以及完成的位号)
  82   1          TSWUTC = 0X0D;//休眠下0.1S唤醒一次触摸按键控制器//需打开低功耗唤醒功能
  83   1          TSRT = 0X00;//IO仅做触摸按键，不分时复用
  84   1          IP2H |= 0X80;
  85   1          
  86   1          TSCTRL = 0XA5;//TSGO = 1，直接开始扫描，等待手动清零TSIF，内部32K晶振，使能低功耗唤醒，重复扫描2次，关
             -闭数字比较器//如果不关数字比较器会卡死
  87   1          Delay_ms(5);//延时5ms，等待触摸按键采样完成
  88   1          
  89   1          TK_P11_Data = TouchKey_Read();//读取按键
  90   1          TK1_Baseline = TK_P11_Data;//初始化基线
  91   1          TK1_Threshold = Touchkey_Threshold_CAL(TK1_Baseline);
  92   1      }
  93              //实测不需要32k低速时钟，触摸模块内部就有32k低速时钟。与定时唤醒器一样，有独立的32k时钟
  94          void RC_Wakeup_Init(){//通过低速RC振荡器，从休眠中定时唤醒
  95   1          IRC32KCR |= 0x80;//使能32K低速时钟，用于唤醒
  96   1          WKTCH = 0XFF;//16秒唤醒一次，启用定时唤醒功能

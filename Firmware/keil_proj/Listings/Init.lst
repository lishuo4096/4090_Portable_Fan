  31   1          WDT_CONTR = 0X37;//初始化看门狗，时间设置为24MHZ时钟下4.2s
  32   1          IRCDB = 0X00;//上电后持续255个时钟后开始执行程序
  33   1      }
  34          void ADC_Init(void){
  35   1          ADC_CONTR = 0X8F;//打开ADC电源，清空中断标志，关闭PWM使能，选择15通道（默认）
  36   1          ADCCFG = 0X21;//ADC转换结果设置为右对齐，ADC时钟设置为系统时钟/4
  37   1          ADCTIM = 0X4A;//ADC通道时间占1个ADC时钟，通道保持3时钟，采样时间11个时钟。
  38   1      }
  39          void PWMA_Init(){
  40   1          P_SW2 |= 0X80;
  41   1          PWMA_PS |= 0XC0;//PWMA4N输出引脚为P33
  42   1          PWMA_CCER2 = 0x00; //写 CCMRx 前必须先清零 CCERx 关闭通道
  43   1          PWMA_CCMR4 = 0x60; //设置 CC4 为 PWMA 输出模式 
  44   1          PWMA_CCER2 = 0xC0; //使能 CC4 通道
  45   1          PWMA_IER = 0X00; //禁用中断
  46   1          PWMA_CCR4 = Duty; //设置比较值，PWM4//这里可以直接写入16位值
  47   1          PWMA_ARR = PWM_Period; //设置计数值//预装载寄存器
  48   1          PWMA_ENO = 0x80; //使能 PWM4N 端口输出 //占空比为反比
  49   1          PWMA_BKR = 0x80; //使能主输出
  50   1          PWMA_CR1 = 0x01; //开始计时
  51   1      }

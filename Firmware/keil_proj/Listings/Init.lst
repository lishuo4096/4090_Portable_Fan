  16   1          P4M0 = 0x00; P4M1 = 0xff;
  17   1          P4IE = 0X00;
  18   1          P5M0 = 0x00; P5M1 = 0xff; 
  19   1          P5IE = 0X00;
  20   1          TXD_PIN = 1;
  21   1          RXD_PIN = 1;

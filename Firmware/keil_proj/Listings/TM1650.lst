 182          //Num为指针（地址），*Num为这个地址读到的东西
 183          void TM1650_Display_Word(const char *Word){
 184   1          bit TM1650_Need_DP = 0;//是否需要小数点标志
 185   1          unsigned char TM1650_Current_Digit = 0;//记录当前写的数码管段
 186   1          unsigned char TM1650_Write_Buffer = 0;//写过程的缓存
 187   1              while(*Word != '\0' && TM1650_Current_Digit < 4){//字符串未结尾，且并没有写完完整4位
 188   2              if(*(Word+1) == '.'){//检测下一位是否是小数点(TM1650的小数点与上一个段绑定)
 189   3                  TM1650_Need_DP = 1;//标记需要小数点
 190   3              }
 191   2              TM1650_Write_Buffer = Seg_Table(*Word);//按字符ASCII值查表
 192   2              if(TM1650_Need_DP){//如果需要小数点
 193   3                  TM1650_Write_Buffer |= 0x80;//最高位置1
 194   3                  TM1650_Need_DP = 0;//清零标志
 195   3                  Word = Word + 1;//下一位存在小数点，直接跳过
 196   3                  }
 197   2              switch(TM1650_Current_Digit){//写入
 198   3                  case 0: TM1650_Write(TM1650_Write_Buffer,TM1650_DIG1); break;
 199   3                  case 1: TM1650_Write(TM1650_Write_Buffer,TM1650_DIG2); break;
 200   3                  case 2: TM1650_Write(TM1650_Write_Buffer,TM1650_DIG3); break;
 201   3                  case 3: TM1650_Write(TM1650_Write_Buffer,TM1650_DIG4); break;
 202   3                  }
 203   2                  TM1650_Current_Digit++;//数码管段+1
 204   2                  Word++;//指针+1
 205   2              }
 206   1      }

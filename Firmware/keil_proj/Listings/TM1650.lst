 164          void TM1650_Init(unsigned int TM1650_Freq_kHz,unsigned char Brt){
 165   1          unsigned char MSSPEED = 0;
 166   1          P_SW2 |= 0X80;//允许访问扩展寄存器
 167   1          if(TM1650_Freq_kHz != 0){//传入0代表不重新初始化I2C

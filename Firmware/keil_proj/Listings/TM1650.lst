 100          static void I2C_CMD(unsigned char CMD){//I2C命令设置
 101   1          unsigned int Release_Timer = 0;
 102   1          I2CMSCR = (I2CMSCR & 0XF0) | CMD;//只填低四位
 103   1          //头文件中没有MSIF的定义，因此只能手动做与运算
 104   1          while(!(I2CMSST & 0X40)){
 105   2              if(++Release_Timer > 10000) {
 106   3                  TM1650_Error = 1;break;}}//等待I2C控制器执行完命令，超时则退出并报错
 107   1          I2CMSCR = (I2CMSCR & 0XF0) | I2C_IDLE;//清空I2C命令
 108   1          I2CMSST &= ~0X40;//清除完成标志(~0X40 = 10111111,做与运算，可清零bit6位)
 109   1      }
 110          static bit I2C_Check_ACK(void){//TM1650不需要确认ACK
 111   1          unsigned char a = 0;
 112   1          a = (I2CMSST & 0X02);//读取I2CMSST B1位是否为1
 113   1          return a;//返回1或0
 114   1      }
 115          static void TM1650_Write(unsigned char Data,unsigned char Addr){//底层发送数据驱动
 116   1          //此处不需I2C开始与停止发送，而是手动添加，可连续发送。
C51 COMPILER V9.60.7.0   TM1650                                                            04/28/2026 12:29:02 PAGE 3   

 117   1          if(Addr != 0){//如果需要在同一地址发送超过8bit数据，可令Addr=0
 118   2              I2C_CMD(I2C_START);
 119   2              I2CTXD = Addr;//不需要担心时序，每字节后必须有一个ack，时间足够
 120   2              I2C_CMD(I2C_SENDMS);//发送命令
 121   2              I2C_CMD(I2C_RECV_ACK);//接受ACK
 122   2              I2CTXD = Data;//先发地址，后发数据
 123   2              I2C_CMD(I2C_SENDMS);
 124   2              I2C_CMD(I2C_RECV_ACK);
 125   2              I2CTXD = 0;//清空发送寄存器
 126   2              I2C_CMD(I2C_STOP);
 127   2          }
 128   1          else{//往一个八位地址一直发数据，比如写OLED屏（特殊设备有16位I2C地址，在这里不做讨论）
 129   2              I2CTXD = Data;//先发地址，后发数据
 130   2              I2C_CMD(I2C_SENDMS);
 131   2              I2C_CMD(I2C_RECV_ACK);
 132   2          }
 133   1      }

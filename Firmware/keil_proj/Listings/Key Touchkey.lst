  67          void Key_Sampling(void){
  68   1        //本函数自带消抖，因为不足一个定时器间隔的下降沿无法触发采样
  69   1        //在30ms定时器中断中调用本函数
  70   1        static  uint8_t Sampling_Counter = 0;//采样次数计数器
  71   1        static  uint32_t Sampling_Temp = 0;//采样结果缓存
  72   1        static bit Previous_Key = false;//之前的按键采样记录
  73   1        static bit Now_Key = false;//当前的按键采样记录
  74   1        static bit Is_Sampling = false;//正在采样标志
  75   1        static bit Start_Sampling = false;//开始采样标志，由下降沿触发
  76   1        static  uint8_t Key_Release_Counter = 0;//超时计数器，可以更快的响应单击和双击操作
  77   1        uint8_t Rise_Edge_Result = 0;//上升沿计算的结果,非static变量，重入自动清零
  78   1        bit Read_Temp = Button;//按键状态缓存，每次进入函数时读取
  79   1        //采样触发(检测下降沿)
  80   1        if(!Is_Sampling){//如果没有在采样，才做判断
  81   2        Previous_Key = Now_Key;//存储上一次的结果
  82   2        Now_Key = Read_Temp;//读取本次结果
  83   2        //Key_Event = NOKEY;//未在采样状态，全局按键事件为无键
  84   2        if((!Now_Key && Previous_Key) || need_wakeup_sampling){//上一次为1，这一次为0，是下降沿
  85   3        Start_Sampling = true;//开始采样
  86   3        }
  87   2        else{
  88   3            Sampling_Counter = 0;Sampling_Temp = 0;Key_Release_Counter = 0;
  89   3          return;}//未触发采样，清空变量，返回
  90   2        }
  91   1        //开始采样与结果处理
  92   1        if(Start_Sampling){
  93   2          if(Sampling_Counter < 32){
  94   3            Is_Sampling = true;
  95   3            Sampling_Temp <<= 1;//整体左移一位,低位补0

 104   5              }
 105   4              }
 106   3              else{//如果按键为低电平
 107   4              Key_Release_Counter = 0;
 108   4              }
 109   3              Sampling_Counter++;
 110   3              }
 111   2            else{//采满32次，采样结束,开始计算
 112   3              Is_Sampling = 0;
 113   3              Start_Sampling = 0;
 114   3              Sampling_Counter = 0;//清空计数器
 115   3              need_wakeup_sampling = 0;

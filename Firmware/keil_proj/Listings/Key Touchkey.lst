  55          static uint8_t Rise_Edge_Counter(unsigned long Input){
  56   1          uint32_t Mask;//掩码
  57   1          //if(Input == 0xffffffff) return 0xff;//如果程序上出现了误采样的话，防止错误给出0上升沿导致误判关机(已

  30          //开始发送时，SPIF = 0，结束发送后SPIF = 1;
  31          static void SPI_Send_1_Byte(unsigned char SPI_Data){
  32   1          SPDAT = SPI_Data;//写入后，硬件置SPIF = 0;
  33   1          while(!(SPSTAT & 0x80));//SPI控制器发送完数据后，退出while循环
  34   1          SPSTAT = 0xC0;//清空中断标志
  35   1      }

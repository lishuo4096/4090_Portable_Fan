   5          static void HSV2RGB(uint8_t h, uint8_t s, uint8_t v, uint8_t *r, uint8_t *g, uint8_t *b) {
   6   1          uint8_t region,p,q,t;
   7   1          uint16_t remainder;
   8   1          if (s == 0) { // 灰度
   9   2              *r = *g = *b = v;
  10   2              return;
  11   2          }
  12   1          region = h / 43; // 将 H 分为 6 个区域，每个区域约 43 度
  13   1          remainder = (h - (region * 43)) * 6; // 计算当前区域内的偏移量
  14   1          p = (v * (255 - s)) >> 8;
  15   1          q = (v * (255 - ((s * remainder) >> 8))) >> 8;
  16   1          t = (v * (255 - ((s * (255 - remainder)) >> 8))) >> 8;
  17   1          switch (region) {
  18   2              case 0: *r = v; *g = t; *b = p; break;
  19   2              case 1: *r = q; *g = v; *b = p; break;
  20   2              case 2: *r = p; *g = v; *b = t; break;
  21   2              case 3: *r = p; *g = q; *b = v; break;
  22   2              case 4: *r = t; *g = p; *b = v; break;
  23   2              default: *r = v; *g = p; *b = q; break;
  24   2          }
  25   1      }

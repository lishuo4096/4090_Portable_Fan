 135          static void WS2812_Brt_Breath(uint8_t Red,uint8_t Green,uint8_t Blue){//30ms时序调用
 136   1          uint16_t Redin = Red;
 137   1          uint16_t Greenin = Green;//转换为int量防止溢出
 138   1          uint16_t Brt_Ratio = (255 * 2);//最大亮度127
 139   1          static uint8_t Redout,Greenout;//在亮度保持状态，退出函数不会丢失
 140   1          switch(Breath_State){
 141   2              case Brt_Rise://亮度增加状态
 142   2                  Redout = (Redin * Breath_Counter)/Brt_Ratio;
 143   2                  Greenout = (Greenin * Breath_Counter)/Brt_Ratio;
 144   2                  if(++Breath_Counter == 255){
 145   3                      Breath_State = Brt_Keep_High;
 146   3                      Breath_Counter = 0;//清空计数器
 147   3                  }
 148   2                  break;
 149   2              case Brt_Keep_High:
 150   2                  if(++Breath_Counter >= 510){
 151   3                      Breath_State = Brt_Fall;
 152   3                      Breath_Counter = 255;//下面会使用这个来计算亮度，因此先赋值
 153   3                  }
 154   2                  break;
 155   2              case Brt_Fall:
 156   2                  Redout = (Redin * Breath_Counter)/Brt_Ratio;
 157   2                  Greenout = (Greenin * Breath_Counter)/Brt_Ratio;
 158   2                  if(--Breath_Counter == 0){
 159   3                      Breath_State = Brt_Keep_Low;
 160   3                      Breath_Counter = 0;
 161   3                  }
 162   2                  break;
 163   2              case Brt_Keep_Low:
 164   2                  if(++Breath_Counter >= 365){
 165   3                      Breath_State = Brt_Rise;
 166   3                      Breath_Counter = 0;
 167   3                  }
 168   2                  break;
 169   2          }
 170   1          WS2812_Send_Data(1, Redout, Greenout, Blue);
 171   1      }
